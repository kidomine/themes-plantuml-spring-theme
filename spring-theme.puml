skinparam backgroundColor white

' Legacy skinparam tuning specifically for clean line, arrow, and label interactions
skinparam ArrowColor #4A5568
skinparam ArrowThickness 1.5
skinparam ArrowFontColor #4A5568
skinparam ArrowFontName "Helvetica Neue", Helvetica, Arial, sans-serif
skinparam ArrowFontSize 10

<style>
element {
  FontColor #2F3E46
  FontName "Helvetica Neue", Helvetica, Arial, sans-serif
  FontSize 12
}

classDiagram {
  ' Base style for all classes
  class {
    RoundCorner 8
  }
  
  ' Spring Green Theme (Core / Beans)
  .Component {
    LineColor #6DB33F
    BackgroundColor #6DB33F20
    header {
      FontStyle bold
      FontColor #6DB33F
    }
  }
  .Configuration {
    LineColor #6DB33F
    BackgroundColor #6DB33F20
    header {
      FontStyle bold
      FontColor #6DB33F
    }
  }
  .Bean {
    LineColor #F1C40F
    BackgroundColor #F1C40F20
    RoundCorner 4
    header {
      FontStyle bold
      FontColor #F1C40F
    }
  }

  ' Soft Web Blue Theme (Web / Presentation)
  .Controller {
    LineColor #2F72B5
    BackgroundColor #2F72B520
    header {
      FontStyle bold
      FontColor #2F72B5
    }
  }
  .RestController {
    LineColor #2F72B5
    BackgroundColor #2F72B520
    header {
      FontStyle bold
      FontColor #2F72B5
    }
  }
  .ControllerAdvice {
    LineColor #2F72B5
    BackgroundColor #2F72B520
    header {
      FontStyle bold
      FontColor #2F72B5
    }
  }

  ' Amber Orange Theme (Service / Business Logic)
  .Service {
    LineColor #E67E22
    BackgroundColor #E67E2220
    header {
      FontStyle bold
      FontColor #E67E22
    }
  }

  ' Royal Purple Theme (Data / Repository)
  .Repository {
    LineColor #8E44AD
    BackgroundColor #8E44AD20
    header {
      FontStyle bold
      FontColor #8E44AD
    }
  }
}

' Additional rules targeting Package and Deployment diagrams
componentDiagram {
  ' Style for standard layout containers like packages or nodes
  package {
    LineColor #718096
    BackgroundColor #71809620
    LineThickness 1.0
    header {
      FontStyle bold
      FontColor #718096
    }
  }
  
  ' Style for physical deployment environments / physical hardware blocks
  node {
    LineColor #2F3E46
    BackgroundColor #2F3E4620
    header {
      FontStyle bold
      FontColor #2F3E46
    }
  }

  ' Structural deployment artifacts (e.g., JAR, WAR) mapping to Spring Green
  artifact {
    LineColor #6DB33F
    BackgroundColor #6DB33F20
    RoundCorner 6
    header {
      FontStyle bold
      FontColor #6DB33F
    }
  }

  ' Running instances/subsystems mapped to the structural Slate/Navy palette
  component {
    LineColor #2F3E46
    BackgroundColor #2F3E4620
    RoundCorner 4
    header {
      FontStyle bold
      FontColor #2F3E46
    }
  }

  ' --- Custom Infrastructure Stereotypes ---
  ' Docker Whale Blue
  .Docker {
    LineColor #1D63ED
    BackgroundColor #1D63ED15
    LineThickness 1.5
    header {
      FontStyle bold
      FontColor #1D63ED
    }
  }
  
  ' AWS Orange
  .AWS {
    LineColor #FF9900
    BackgroundColor #FF990015
    LineThickness 1.5
    header {
      FontStyle bold
      FontColor #FF9900
    }
  }
  
  ' Azure Blue
  .Azure {
    LineColor #0078D4
    BackgroundColor #0078D415
    LineThickness 1.5
    header {
      FontStyle bold
      FontColor #0078D4
    }
  }
}
</style>
